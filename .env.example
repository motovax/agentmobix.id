# Mobix API bearer token. Used ONLY server-side by the Vite dev proxy
# (vite.config.ts) and any production reverse proxy — never shipped to the
# browser. Copy this file to `.env` and fill the value.
MOBIX_API_KEY=

# Base URL of the Mobix API (optional; defaults to production).
MOBIX_API_BASE=https://mobix.motovax.com

# Strapi CMS API (api.mobixbydss.id) bearer token — server-side only.
STRAPI_API_KEY=

# Base URL of the CMS API (optional; defaults to production).
CMS_API_BASE=https://api.mobixbydss.id

# DSF credit simulation API — server-side only (Cloudflare Worker secret + Vite dev proxy).
DSF_BEARER_TOKEN=

# Base URL of DSF simulation API (optional; defaults to production).
DSF_BASE_URL=https://simulation.dipostar.com
